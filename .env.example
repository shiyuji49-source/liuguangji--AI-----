# ===== 数据库 =====
DATABASE_URL=postgres://liuguangji:liuguangji@localhost:5432/liuguangji

# ===== 认证 =====
AUTH_SECRET=change-me-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
# 平台管理员种子账号（npm run db:seed 时创建）
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# ===== LLM（乐奇API，Anthropic 原生兼容端点）=====
LLM_BASE_URL=https://lqapi.top
LLM_API_KEY=lq-xxx
# 鉴权头风格：bearer（乐奇）| x-api-key（Anthropic 官方，供应商切换预案）
LLM_AUTH_STYLE=bearer
LLM_MODEL_HEAVY=claude-opus-4-8
LLM_MODEL_MAIN=claude-sonnet-4-6

# ===== 图片（乐奇API，P1）=====
OPENAI_BASE_URL=https://lqapi.top/v1
OPENAI_API_KEY=lq-xxx
OPENAI_CONCURRENCY=2

# ===== 视频（火山方舟，P2）=====
ARK_API_KEY=
ARK_CONCURRENCY=2

# ===== 邮件（邮箱注册/找回密码，P0 必配）=====
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="鎏光机 <no-reply@example.com>"

# ===== 短信（手机号注册，可选模块；不配置则注册页只显示邮箱）=====
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# ===== 存储（P1）=====
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=/data/assets

# Kimi（月之暗面）官方 API（可选：A/B 测试或替换主模型）
KIMI_BASE_URL=https://api.moonshot.cn/anthropic
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.6

# 内测：false=关闭公开注册（admin 后台建号）
ALLOW_REGISTRATION=true
# 生产 compose 用的数据库密码（docker-compose.yml 读取）
DB_PASSWORD=

# 新用户注册赠送积分（0=不送；内测设 5000）
SIGNUP_BONUS_CREDITS=0

# 图片生成网关：OpenRouter（gpt-image-2 + gemini-3-pro-image 统一走这里）
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
